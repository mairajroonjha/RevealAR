{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "revealar-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-25",
  "observability": {
    "enabled": true
  },
  "vars": {
    "AI_GATEWAY_BASE_URL": "https://gateway.ai.cloudflare.com/v1/YOUR_ACCOUNT_ID/revealar"
  },
  "r2_buckets": [
    {
      "binding": "ROOM_ASSETS",
      "bucket_name": "revealar-room-assets"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "JOB_CACHE",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "revealar-db",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "AI_JOBS",
        "queue": "revealar-ai-jobs"
      }
    ],
    "consumers": [
      {
        "queue": "revealar-ai-jobs",
        "max_batch_size": 1,
        "max_batch_timeout": 30
      }
    ]
  }
}
